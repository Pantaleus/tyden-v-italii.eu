# Deny access to sensitive files
<FilesMatch "^\.env|database\.sql|composer\.(json|lock)|seed\.php$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # 1. If request is a real file, serve it directly
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^ - [L]

    # 2. If the file exists inside public/, rewrite to it (e.g. css/style.css -> public/css/style.css)
    RewriteCond %{DOCUMENT_ROOT}/public/$1 -f
    RewriteRule ^(.*)$ public/$1 [L]

    # 3. Route admin requests
    RewriteRule ^admin(/(.*))?$ admin/index.php [QSA,L]

    # 4. Route all other requests (including /) to public/index.php
    RewriteRule ^(.*)$ public/index.php [QSA,L]
</IfModule>

